    <!-- SKRIPTY PRO FIREBASE A ADMIN MÓD -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, doc, setDoc, onSnapshot } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // Admin Toggle
        let clickCount = 0;
        const heading = document.getElementById('nabidka-heading');
        const toast = document.getElementById('toast');

        function showToast(msg) {
            toast.textContent = msg;
            toast.classList.remove('translate-y-full', 'opacity-0');
            setTimeout(() => {
                toast.classList.add('translate-y-full', 'opacity-0');
            }, 3000);
        }

        heading.addEventListener('click', () => {
            clickCount++;
            if (clickCount === 3) {
                document.body.classList.toggle('admin-mode');
                const isAdmin = document.body.classList.contains('admin-mode');
                showToast(isAdmin ? 'ADMIN MÓD AKTIVNÍ: Kliknutím na položky je vyprodáš' : 'ADMIN MÓD VYPNUT');
                clickCount = 0;
            }
            setTimeout(() => clickCount = 0, 1000); // Reset za vteřinu
        });

        // Firebase State Management (Tvůj skutečný projekt)
        let db, statusDocRef;
        let inventoryStatus = {};
        let isFirebaseActive = false;

        const firebaseConfig = {
          apiKey: "AIzaSyABgqLHrBC1OR2nYDb_RzxahVC7p6LGrfs",
          authDomain: "statek-syrovatkovi.firebaseapp.com",
          projectId: "statek-syrovatkovi",
          storageBucket: "statek-syrovatkovi.firebasestorage.app",
          messagingSenderId: "125056792501",
          appId: "1:125056792501:web:e1fa9f8038cc90fe994bfc"
        };

        try {
            // Zkontrolujeme, zda jsme v testovacím prostředí s vlastními proměnnými
            const isTestEnv = typeof __firebase_config !== 'undefined';
            
            // Pokud jsme v testovacím prostředí, použijeme jeho config, jinak tvůj
            const app = initializeApp(isTestEnv ? JSON.parse(__firebase_config) : firebaseConfig);
            const auth = getAuth(app);
            db = getFirestore(app);
            isFirebaseActive = true;
            
            const appId = typeof __app_id !== 'undefined' ? __app_id : 'syrovatkovi-statek-123';

            const initAuth = async () => {
                try {
                    // Prioritně zkusíme custom token z testovacího prostředí
                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await signInWithCustomToken(auth, __initial_auth_token);
                    } else {
                        // Jinak zkusíme anonymní přihlášení
                        await signInAnonymously(auth);
                    }
                } catch(e) { 
                    console.error("Auth error:", e);
                    showToast("Nelze se připojit k databázi.");
                }
            };

            initAuth();

            onAuthStateChanged(auth, (user) => {
                if (!user) return;
                
                // OPRAVA: Firebase vyžaduje sudý počet segmentů pro doc().
                // Původní: artifacts / appId / public / data / inventory (5 segmentů - CHYBA)
                // Nové: artifacts / appId / public / data / inventory / status (6 segmentů - SPRÁVNĚ)
                statusDocRef = doc(db, 'artifacts', appId, 'public', 'data', 'inventory', 'status');

                onSnapshot(statusDocRef, (docSnap) => {
                    if (docSnap.exists()) {
                        inventoryStatus = docSnap.data();
                    } else {
                        inventoryStatus = {};
                    }
                    renderInventory();
                }, (error) => console.error(error));
            });
        } catch(e) {
            console.error("Firebase se nenačetl.", e);
        }

        function renderInventory() {
            document.querySelectorAll('.product-row').forEach(row => {
                const id = row.getAttribute('data-id');
                const isSoldOut = inventoryStatus[id] === true;
                const badge = row.querySelector('.sold-out-badge');

                if (isSoldOut) {
                    row.classList.remove('opacity-30'); // Odstranění původního zprůhlednění celého bloku
                    row.classList.add('is-sold-out');   // Přidání nové třídy jen pro text
                    badge.classList.remove('hidden');
                } else {
                    row.classList.remove('opacity-30');
                    row.classList.remove('is-sold-out');
                    badge.classList.add('hidden');
                }
            });
        }

        // Akce při kliknutí na řádek
        document.querySelectorAll('.product-row').forEach(row => {
            row.addEventListener('click', async () => {
                if (!document.body.classList.contains('admin-mode')) return;

                const id = row.getAttribute('data-id');
                const currentState = inventoryStatus[id] || false;
                const newState = !currentState;

                // Okamžitá změna v UI (optimistic update)
                inventoryStatus[id] = newState;
                renderInventory();

                if (isFirebaseActive && statusDocRef) {
                    try {
                        // Odeslání do databáze (všichni ostatní to uvidí do půl vteřiny)
                        await setDoc(statusDocRef, { [id]: newState }, { merge: true });
                    } catch(e) {
                        console.error("Uložení selhalo.", e);
                        showToast('Chyba při ukládání na server!');
                        inventoryStatus[id] = currentState; // návrat zpět
                        renderInventory();
                    }
                }
            });
        });
    </script>

    <!-- SKRIPTY PRO CAROUSEL -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const track = document.getElementById('carousel-track');
            const dotButtons = document.querySelectorAll('.carousel-dot');
            let currentIndex = 0;
            let autoPlayInterval;

            function updateCarousel(index) {
                // Posun pásu s fotkami
                track.style.transform = `translateX(-${index * 100}%)`;
                
                // Aktualizace vzhledu teček
                dotButtons.forEach((btn, i) => {
                    const dotInner = btn.querySelector('.dot-inner');
                    if (i === index) {
                        dotInner.classList.remove('bg-white/50');
                        dotInner.classList.add('bg-white');
                    } else {
                        dotInner.classList.remove('bg-white');
                        dotInner.classList.add('bg-white/50');
                    }
                });
                currentIndex = index;
            }

            // Přidání chování na kliknutí teček
            dotButtons.forEach(btn => {
                btn.addEventListener('click', () => {
                    const index = parseInt(btn.getAttribute('data-index'));
                    updateCarousel(index);
                    resetAutoPlay(); // Při ručním přepnutí restartujeme odpočet
                });
            });

            // Automatické přepínání
            function startAutoPlay() {
                autoPlayInterval = setInterval(() => {
                    let nextIndex = (currentIndex + 1) % dotButtons.length;
                    updateCarousel(nextIndex);
                }, 4000); // 4000 ms = 4 sekundy
            }

            function resetAutoPlay() {
                clearInterval(autoPlayInterval);
                startAutoPlay();
            }

            // Spuštění po načtení
            startAutoPlay();
        });
    </script>
